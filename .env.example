# ── Required ───────────────────────────────────────────────────────────────
# OpenSea API key. Grab one instantly (no signup):
#   curl -X POST https://api.opensea.io/api/v2/auth/keys
# For higher rate limits later: https://opensea.io/settings/developer
OPENSEA_API_KEY=

# Discord channel webhook. In Discord: Channel → Edit Channel → Integrations →
# Webhooks → New Webhook → Copy Webhook URL.
DISCORD_WEBHOOK_URL=

# ── Collection (pre-filled for NullThread; change to reuse for any collection) ─
COLLECTION_SLUG=nullthread-by-heefleursss
CONTRACT_ADDRESS=0xc1b068f82b4bc552bf27db6a5ec983a89bfcb6d9
COLLECTION_NAME=NullThread
COLLECTION_ICON=https://i2c.seadn.io/collection/nullthread-395904459/image_type_logo/2be99ce634baff4fe56a51c9b7d3e4/372be99ce634baff4fe56a51c9b7d3e4.gif

# Embed accent color (left bar). Default = amber. Hex with 0x prefix.
EMBED_COLOR=0xF4A340
